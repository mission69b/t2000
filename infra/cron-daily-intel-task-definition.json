{
  "family": "t2000-cron-daily-intel",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "${EXEC_ROLE_ARN}",
  "containerDefinitions": [
    {
      "name": "t2000-cron-daily-intel",
      "image": "${ECR_BASE}/t2000-indexer:latest",
      "command": ["node", "dist/cron/index.js"],
      "essential": true,
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "${LOG_GROUP}",
          "awslogs-region": "${AWS_REGION}",
          "awslogs-stream-prefix": "t2000-cron-daily-intel"
        }
      },
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "CRON_GROUP", "value": "daily-intel" },
        { "name": "T2000_PACKAGE_ID", "value": "0xd775fcc66eae26797654d435d751dea56b82eeb999de51fd285348e573b968ad" },
        { "name": "T2000_FIN_CTX_SHARD_COUNT", "value": "24" }
      ],
      "secrets": [
        {
          "name": "SUI_RPC_URL",
          "valueFrom": "arn:aws:secretsmanager:${AWS_REGION}:${AWS_ACCOUNT_ID}:secret:t2000/mainnet/sui-rpc-url"
        },
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:${AWS_REGION}:${AWS_ACCOUNT_ID}:secret:t2000/mainnet/database-url"
        },
        {
          "name": "ADMIN_PRIVATE_KEY",
          "valueFrom": "arn:aws:secretsmanager:${AWS_REGION}:${AWS_ACCOUNT_ID}:secret:t2000/mainnet/admin-key"
        },
        {
          "name": "RESEND_API_KEY",
          "valueFrom": "arn:aws:secretsmanager:${AWS_REGION}:${AWS_ACCOUNT_ID}:secret:t2000/mainnet/resend-api-key"
        },
        {
          "name": "AUDRIC_INTERNAL_URL",
          "valueFrom": "arn:aws:secretsmanager:${AWS_REGION}:${AWS_ACCOUNT_ID}:secret:t2000/mainnet/audric-internal-url"
        },
        {
          "name": "AUDRIC_INTERNAL_KEY",
          "valueFrom": "arn:aws:secretsmanager:${AWS_REGION}:${AWS_ACCOUNT_ID}:secret:t2000/mainnet/audric-internal-key"
        }
      ]
    }
  ]
}
