{
  "name": "@t2000/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@hono/node-server": "^1",
    "@mysten/sui": "^2.13.0",
    "@prisma/client": "^6",
    "@t2000/sdk": "workspace:*",
    "eventemitter3": "^5",
    "hono": "^4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "eslint": "^9",
    "prisma": "^6",
    "tsup": "^8",
    "tsx": "^4",
    "typescript": "^5",
    "vitest": "^3"
  }
}
