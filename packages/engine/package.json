    "ai",
    "agent",
    "engine",
    "llm",
    "finance",
    "t2000",
    "audric"
  ],
  "author": "t2000",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mission69b/t2000.git",
    "directory": "packages/engine"
  },
  "homepage": "https://t2000.ai",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
