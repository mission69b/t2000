{
  "name": "@mppsui/discovery",
  "version": "0.1.0",
  "description": "Sui-specific discovery validation for MPP servers — validate OpenAPI documents and probe 402 payment challenges",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mppsui-discovery": "./bin/discovery.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "keywords": [
    "mpp",
    "sui",
    "discovery",
    "openapi",
    "402",
    "payment",
    "validation",
    "usdc",
    "agent"
  ],
  "author": "mppsui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mission69b/t2000.git",
    "directory": "packages/discovery"
  },
  "homepage": "https://mppsui.dev",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20",
    "eslint": "^9",
    "tsup": "^8",
    "typescript": "^5",
    "vitest": "^3"
  },
  "license": "MIT"
}
