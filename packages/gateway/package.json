{
  "name": "@t2000/gateway",
  "version": "0.19.1",
  "description": "Personal AI financial advisor — local gateway with Telegram, WebChat, and heartbeat",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@hono/node-server": "^1",
    "@t2000/sdk": "workspace:*",
    "hono": "^4",
    "openai": "^4.85.0",
    "grammy": "^1.35.0",
    "node-cron": "^3.0.3",
    "zod": "^3.25.0",
    "zod-to-json-schema": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "eslint": "^9",
    "tsup": "^8",
    "typescript": "^5",
    "vitest": "^3"
  },
  "license": "MIT"
}
